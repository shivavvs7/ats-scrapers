DATABASE_URL=# for saving jobs to database
OPENAI_API_KEY=# for embeddings
SERPAPI_API_KEY=# for finding companies (SERP API)

# Optional: Alternative discovery methods
SEARXNG_URL=# SearXNG instance (e.g., http://localhost:8080)
SEARXNG_USE_CLOUD=# Enable cloud SearXNG instances (true/false, default: false)
SEARXNG_INSTANCES_FILE=# Path to instances JSON (default: z_searxng_instances.json)
SEARXNG_MIN_INSTANCE_COOLDOWN=# Seconds between requests to same instance (default: 30)
SEARXNG_ENGINES=# Comma-separated search engines (default: google,bing,wikipedia)
SEARXNG_REQUEST_DELAY=# Seconds between page requests (default: 1.0)
FIRECRAWL_API_KEY=# Firecrawl API 
GOOGLE_API_KEY=# Google Custom Search API 
GOOGLE_CSE_ID=# Custom Search Engine ID
BING_API_KEY=# Bing Search

USER_DATA_DIR=#Posts